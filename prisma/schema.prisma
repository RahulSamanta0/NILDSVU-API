generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model appointments {
  appointment_id                         BigInt              @id @default(autoincrement())
  tenant_id                              BigInt
  facility_id                            BigInt?
  appointment_number                     String              @unique @db.VarChar(50)
  patient_id                             BigInt
  appointment_date                       DateTime            @db.Date
  appointment_time                       DateTime            @db.Time(6)
  appointment_type                       String?             @db.VarChar(50)
  department_id                          Int?
  doctor_id                              BigInt?
  therapist_id                           BigInt?
  reason                                 String?
  status                                 appointment_status? @default(scheduled)
  booked_by                              String?             @db.VarChar(50)
  confirmation_sent                      Boolean?            @default(false)
  reminder_sent                          Boolean?            @default(false)
  created_at                             DateTime?           @default(now()) @db.Timestamp(6)
  updated_at                             DateTime?           @default(now()) @db.Timestamp(6)
  cancellation_reason                    String?             @db.VarChar(255)
  departments                            departments?        @relation(fields: [department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_appointments_department")
  users_appointments_doctor_idTousers    users?              @relation("appointments_doctor_idTousers", fields: [doctor_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_appointments_doctor")
  facilities                             facilities?         @relation(fields: [facility_id], references: [facility_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_appointments_facility")
  patients                               patients            @relation(fields: [patient_id], references: [patient_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_appointments_patient")
  tenants                                tenants             @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_appointments_tenant")
  users_appointments_therapist_idTousers users?              @relation("appointments_therapist_idTousers", fields: [therapist_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_appointments_therapist")
  opd_visits                             opd_visits[]

  @@unique([tenant_id, appointment_number], map: "idx_appointments_number")
  @@index([tenant_id, appointment_date, status], map: "idx_appointments_date_status")
  @@index([tenant_id, doctor_id, appointment_date, status], map: "idx_appointments_doctor")
  @@index([tenant_id, patient_id, appointment_date], map: "idx_appointments_patient")
  @@index([tenant_id, status], map: "idx_appointments_status")
}

model audit_logs {
  audit_id   BigInt    @id @default(autoincrement())
  tenant_id  BigInt
  table_name String    @db.VarChar(100)
  record_id  BigInt
  action     String    @db.VarChar(50)
  old_values Json?
  new_values Json?
  user_id    BigInt?
  ip_address String?   @db.VarChar(50)
  user_agent String?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  tenants    tenants   @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_audit_tenant")
  users      users?    @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_audit_user")

  @@index([tenant_id, created_at], map: "idx_audit_created")
  @@index([tenant_id, table_name, record_id], map: "idx_audit_table_record")
  @@index([tenant_id, user_id, created_at], map: "idx_audit_user")
}

model backup_policies {
  policy_id        BigInt        @id @default(autoincrement())
  tenant_id        BigInt
  policy_name      String        @db.VarChar(100)
  schedule_cron    String        @db.VarChar(100)
  retention_days   Int
  storage_location String?       @db.VarChar(255)
  is_active        Boolean?      @default(true)
  created_at       DateTime?     @default(now()) @db.Timestamp(6)
  tenants          tenants       @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_backup_policies_tenant")
  backup_runs      backup_runs[]

  @@unique([tenant_id, policy_name], map: "idx_backup_policy_name")
}

model backup_runs {
  run_id           BigInt          @id @default(autoincrement())
  tenant_id        BigInt
  policy_id        BigInt
  run_started_at   DateTime?       @default(now()) @db.Timestamp(6)
  run_completed_at DateTime?       @db.Timestamp(6)
  status           String?         @default("pending") @db.VarChar(50)
  backup_size_mb   Int?
  checksum         String?         @db.VarChar(128)
  storage_uri      String?         @db.VarChar(500)
  backup_policies  backup_policies @relation(fields: [policy_id], references: [policy_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_backup_runs_policy")
  tenants          tenants         @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_backup_runs_tenant")

  @@index([tenant_id, policy_id, run_started_at], map: "idx_backup_runs")
}

model beds {
  bed_id         Int              @id @default(autoincrement())
  tenant_id      BigInt
  ward_id        Int
  bed_number     String           @db.VarChar(50)
  bed_type       String?          @db.VarChar(50)
  is_occupied    Boolean?         @default(false)
  is_active      Boolean?         @default(true)
  created_at     DateTime?        @default(now()) @db.Timestamp(6)
  tenants        tenants          @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_beds_tenant")
  wards          wards            @relation(fields: [ward_id], references: [ward_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_beds_ward")
  ipd_admissions ipd_admissions[]

  @@unique([tenant_id, ward_id, bed_number], map: "idx_beds_ward_number")
  @@index([tenant_id, is_occupied, is_active], map: "idx_beds_availability")
}

model bill_items {
  bill_item_id BigInt    @id @default(autoincrement())
  tenant_id    BigInt
  bill_id      BigInt
  service_type String    @db.VarChar(100)
  service_id   Int?
  service_name String    @db.VarChar(255)
  quantity     Int?      @default(1)
  unit_price   Decimal   @db.Decimal(10, 2)
  total_price  Decimal   @db.Decimal(12, 2)
  discount     Decimal?  @default(0) @db.Decimal(10, 2)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  bills        bills     @relation(fields: [bill_id], references: [bill_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bill_items_bill")
  tenants      tenants   @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bill_items_tenant")

  @@index([tenant_id, bill_id], map: "idx_bill_items")
}

model bills {
  bill_id           BigInt          @id @default(autoincrement())
  tenant_id         BigInt
  facility_id       BigInt?
  bill_number       String          @unique @db.VarChar(50)
  patient_id        BigInt
  visit_id          BigInt?
  admission_id      BigInt?
  bill_type         String          @db.VarChar(50)
  bill_date         DateTime?       @default(now()) @db.Timestamp(6)
  total_amount      Decimal         @default(0) @db.Decimal(12, 2)
  discount_amount   Decimal?        @default(0) @db.Decimal(12, 2)
  tax_amount        Decimal?        @default(0) @db.Decimal(12, 2)
  net_amount        Decimal         @default(0) @db.Decimal(12, 2)
  paid_amount       Decimal?        @default(0) @db.Decimal(12, 2)
  balance_amount    Decimal?        @default(0) @db.Decimal(12, 2)
  payment_status    billing_status? @default(unpaid)
  concession_type   String?         @db.VarChar(100)
  concession_reason String?
  generated_by      BigInt?
  created_at        DateTime?       @default(now()) @db.Timestamp(6)
  updated_at        DateTime?       @default(now()) @db.Timestamp(6)
  bill_items        bill_items[]
  ipd_admissions    ipd_admissions? @relation(fields: [admission_id], references: [admission_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bills_admission")
  facilities        facilities?     @relation(fields: [facility_id], references: [facility_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bills_facility")
  users             users?          @relation(fields: [generated_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bills_generator")
  patients          patients        @relation(fields: [patient_id], references: [patient_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bills_patient")
  tenants           tenants         @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bills_tenant")
  opd_visits        opd_visits?     @relation(fields: [visit_id], references: [visit_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bills_visit")
  payments          payments[]

  @@unique([tenant_id, bill_number], map: "idx_bills_number")
  @@index([tenant_id, bill_date], map: "idx_bills_date")
  @@index([tenant_id, patient_id, bill_date], map: "idx_bills_patient")
  @@index([tenant_id, payment_status, bill_date], map: "idx_bills_status")
}

model connection_pool_settings {
  setting_id           BigInt    @id @default(autoincrement())
  tenant_id            BigInt
  pool_mode            String?   @db.VarChar(50)
  max_client_conn      Int?
  default_pool_size    Int?
  reserve_pool_size    Int?
  idle_timeout_seconds Int?
  statement_timeout_ms Int?
  created_at           DateTime? @default(now()) @db.Timestamp(6)
  tenants              tenants   @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_pool_tenant")

  @@index([tenant_id], map: "idx_pool_tenant")
}

model cssd_instrument_sets {
  set_id        Int             @id @default(autoincrement())
  tenant_id     BigInt
  set_code      String          @unique @db.VarChar(50)
  set_name      String          @db.VarChar(255)
  set_type      String?         @db.VarChar(100)
  item_count    Int?
  is_active     Boolean?        @default(true)
  created_at    DateTime?       @default(now()) @db.Timestamp(6)
  tenants       tenants         @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cssd_sets_tenant")
  cssd_requests cssd_requests[]

  @@unique([tenant_id, set_code], map: "idx_cssd_set_code")
}

model cssd_requests {
  request_id               BigInt               @id @default(autoincrement())
  tenant_id                BigInt
  request_number           String               @unique @db.VarChar(50)
  requesting_department_id Int
  set_id                   Int
  quantity                 Int?                 @default(1)
  urgency                  priority_level?      @default(normal)
  requested_by             BigInt?
  request_time             DateTime?            @default(now()) @db.Timestamp(6)
  status                   request_status?      @default(pending)
  completed_at             DateTime?            @db.Timestamp(6)
  created_at               DateTime?            @default(now()) @db.Timestamp(6)
  departments              departments          @relation(fields: [requesting_department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cssd_requests_dept")
  users                    users?               @relation(fields: [requested_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cssd_requests_requester")
  cssd_instrument_sets     cssd_instrument_sets @relation(fields: [set_id], references: [set_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cssd_requests_set")
  tenants                  tenants              @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cssd_requests_tenant")

  @@unique([tenant_id, request_number], map: "idx_cssd_request_number")
  @@index([tenant_id, status, request_time], map: "idx_cssd_status")
}

model cssd_sterilization_cycles {
  cycle_id             BigInt    @id @default(autoincrement())
  tenant_id            BigInt
  batch_number         String    @unique @db.VarChar(50)
  autoclave_machine_id String?   @db.VarChar(50)
  load_type            String?   @db.VarChar(50)
  start_time           DateTime  @db.Timestamp(6)
  end_time             DateTime? @db.Timestamp(6)
  temperature_log      Json?
  pressure_log         Json?
  cycle_result         String?   @db.VarChar(50)
  technician_id        BigInt?
  created_at           DateTime? @default(now()) @db.Timestamp(6)
  users                users?    @relation(fields: [technician_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cssd_cycles_tech")
  tenants              tenants   @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cssd_cycles_tenant")

  @@unique([tenant_id, batch_number], map: "idx_cssd_batch")
  @@index([tenant_id, start_time], map: "idx_cssd_start_time")
}

model data_retention_policies {
  retention_id         BigInt    @id @default(autoincrement())
  tenant_id            BigInt
  data_domain          String    @db.VarChar(100)
  retention_years      Int
  archive_after_months Int
  is_active            Boolean?  @default(true)
  created_at           DateTime? @default(now()) @db.Timestamp(6)
  tenants              tenants   @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_retention_tenant")

  @@unique([tenant_id, data_domain], map: "idx_retention_domain")
}

model departments {
  department_id          Int                      @id @default(autoincrement())
  tenant_id              BigInt
  facility_id            BigInt?
  department_name        String                   @db.VarChar(100)
  department_code        String                   @db.VarChar(50)
  department_type        String?                  @db.VarChar(50)
  head_of_department     BigInt?
  contact_number         String?                  @db.VarChar(20)
  is_active              Boolean?                 @default(true)
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  location               String?                  @db.VarChar(255)
  appointments           appointments[]
  cssd_requests          cssd_requests[]
  facilities             facilities?              @relation(fields: [facility_id], references: [facility_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_departments_facility")
  users                  users?                   @relation(fields: [head_of_department], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_departments_head")
  tenants                tenants                  @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_departments_tenant")
  duty_roster            duty_roster[]
  inventory_transactions inventory_transactions[]
  linen_requests         linen_requests[]
  opd_visits             opd_visits[]
  staff_profiles         staff_profiles[]
  visitor_logs           visitor_logs[]

  @@unique([tenant_id, department_code], map: "idx_departments_code")
  @@index([tenant_id, is_active], map: "idx_departments_active")
}

model discharge_summaries {
  summary_id                                                              BigInt           @id @default(autoincrement())
  tenant_id                                                               BigInt
  admission_id                                                            BigInt           @unique
  patient_id                                                              BigInt
  final_diagnosis                                                         String?
  procedures_performed                                                    String?
  treatment_summary                                                       String?
  medications_at_discharge                                                String?
  follow_up_instructions                                                  String?
  discharge_advice                                                        String?
  doctor_id                                                               BigInt
  created_at                                                              DateTime?        @default(now()) @db.Timestamp(6)
  ipd_admissions_discharge_summaries_admission_idToipd_admissions         ipd_admissions   @relation("discharge_summaries_admission_idToipd_admissions", fields: [admission_id], references: [admission_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_summaries_admission")
  users                                                                   users            @relation(fields: [doctor_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_summaries_doctor")
  patients                                                                patients         @relation(fields: [patient_id], references: [patient_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_summaries_patient")
  tenants                                                                 tenants          @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_summaries_tenant")
  ipd_admissions_ipd_admissions_discharge_summary_idTodischarge_summaries ipd_admissions[] @relation("ipd_admissions_discharge_summary_idTodischarge_summaries")

  @@unique([tenant_id, admission_id], map: "idx_discharge_admission")
  @@index([tenant_id, patient_id], map: "idx_discharge_patient")
}

model drugs {
  drug_id             Int                   @id @default(autoincrement())
  tenant_id           BigInt
  drug_code           String                @unique @db.VarChar(50)
  drug_name           String                @db.VarChar(255)
  generic_name        String?               @db.VarChar(255)
  drug_category       String?               @db.VarChar(100)
  dosage_form         String?               @db.VarChar(50)
  strength            String?               @db.VarChar(100)
  manufacturer        String?               @db.VarChar(255)
  is_active           Boolean?              @default(true)
  created_at          DateTime?             @default(now()) @db.Timestamp(6)
  tenants             tenants               @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_drugs_tenant")
  pharmacy_sale_items pharmacy_sale_items[]
  pharmacy_stock      pharmacy_stock[]
  prescription_items  prescription_items[]
  purchase_order_items purchase_order_items[]

  @@unique([tenant_id, drug_code], map: "idx_drugs_code")
  @@index([tenant_id, drug_name], map: "idx_drugs_name")
}

model duty_roster {
  roster_id          BigInt               @id @default(autoincrement())
  tenant_id          BigInt
  staff_id           BigInt
  duty_date          DateTime             @db.Date
  shift_type         shift_type?
  start_time         DateTime             @db.Time(6)
  end_time           DateTime             @db.Time(6)
  department_id      Int?
  is_available       Boolean?             @default(true)
  remarks            String?
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  attendance_records attendance_records[]
  departments        departments?         @relation(fields: [department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_roster_department")
  staff_profiles     staff_profiles       @relation(fields: [staff_id], references: [profile_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_roster_staff")
  tenants            tenants              @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_roster_tenant")

  @@unique([tenant_id, staff_id, duty_date], map: "idx_duty_roster_unique_staff_date")
  @@index([tenant_id, duty_date, department_id], map: "idx_duty_date_dept")
  @@index([tenant_id, staff_id, duty_date], map: "idx_duty_roster")
}

model facilities {
  facility_id      BigInt             @id @default(autoincrement())
  tenant_id        BigInt
  facility_code    String             @unique @db.VarChar(50)
  facility_name    String             @db.VarChar(255)
  facility_type    String?            @db.VarChar(100)
  address_line1    String?            @db.VarChar(255)
  address_line2    String?            @db.VarChar(255)
  city             String?            @db.VarChar(100)
  state            String?            @db.VarChar(100)
  pincode          String?            @db.VarChar(10)
  contact_number   String?            @db.VarChar(20)
  is_active        Boolean?           @default(true)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  appointments     appointments[]
  bills            bills[]
  departments      departments[]
  tenants          tenants            @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_facilities_tenant")
  ipd_admissions   ipd_admissions[]
  lab_test_orders  lab_test_orders[]
  opd_visits       opd_visits[]
  patients         patients[]
  payments         payments[]
  pharmacy_sales   pharmacy_sales[]
  pharmacy_stock   pharmacy_stock[]
  radiology_orders radiology_orders[]
  therapy_orders   therapy_orders[]
  users            users[]
  wards            wards[]
  ambulances       ambulances[]
  ambulance_calls  ambulance_calls[]

  @@unique([tenant_id, facility_code], map: "idx_facilities_code")
  @@index([tenant_id, is_active], map: "idx_facilities_active")
}

model inventory_categories {
  category_id                Int                    @id @default(autoincrement())
  tenant_id                  BigInt
  category_name              String                 @db.VarChar(100)
  category_code              String                 @db.VarChar(50)
  parent_category_id         Int?
  description                String?
  is_active                  Boolean?               @default(true)
  created_at                 DateTime?              @default(now()) @db.Timestamp(6)
  inventory_categories       inventory_categories?  @relation("inventory_categoriesToinventory_categories", fields: [parent_category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_inv_categories_parent")
  other_inventory_categories inventory_categories[] @relation("inventory_categoriesToinventory_categories")
  tenants                    tenants                @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_inv_categories_tenant")
  inventory_items            inventory_items[]

  @@unique([tenant_id, category_code], map: "idx_inventory_category_code")
}

model inventory_items {
  item_id                BigInt                   @id @default(autoincrement())
  tenant_id              BigInt
  item_code              String                   @unique @db.VarChar(50)
  item_name              String                   @db.VarChar(255)
  category_id            Int?
  description            String?
  unit_of_measure        String?                  @db.VarChar(50)
  reorder_level          Int?                     @default(10)
  current_stock          Int?                     @default(0)
  unit_price             Decimal?                 @db.Decimal(10, 2)
  is_active              Boolean?                 @default(true)
  created_at             DateTime?                @default(now()) @db.Timestamp(6)
  updated_at             DateTime?                @default(now()) @db.Timestamp(6)
  inventory_categories   inventory_categories?    @relation(fields: [category_id], references: [category_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_inv_items_category")
  tenants                tenants                  @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_inv_items_tenant")
  inventory_transactions inventory_transactions[]
  purchase_order_items   purchase_order_items[]
  // vendor_items           vendor_items[]
  // grn_items              grn_items[]
  // department_stock       department_stock[]

  @@unique([tenant_id, item_code], map: "idx_inventory_code")
  @@index([tenant_id, category_id], map: "idx_inventory_category")
  @@index([tenant_id, current_stock], map: "idx_inventory_stock")
}



model inventory_transactions {
  transaction_id                                   BigInt             @id @default(autoincrement())
  tenant_id                                        BigInt
  item_id                                          BigInt
  transaction_type                                 inventory_txn_type
  transaction_date                                 DateTime?          @default(now()) @db.Timestamp(6)
  quantity                                         Int
  reference_number                                 String?            @db.VarChar(100)
  department_id                                    Int?
  issued_to                                        BigInt?
  return_id                                        BigInt?
  supplier_id                                      BigInt?
  reason                                           String?
  status                                           return_status?
  damage_type                                      String?            @db.VarChar(100)
  picked_up_at                                     DateTime?          @db.Timestamp(6)
  remarks                                          String?
  performed_by                                     BigInt?
  created_at                                       DateTime?          @default(now()) @db.Timestamp(6)
  departments                                      departments?       @relation(fields: [department_id], references: [department_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_inv_trans_department")
  users_inventory_transactions_issued_toTousers    users?             @relation("inventory_transactions_issued_toTousers", fields: [issued_to], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_inv_trans_issued_to")
