  processing_error  String?
  created_at        DateTime?             @default(now()) @db.Timestamp(6)
  tenants           tenants               @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bio_log_tenant")
  staff_profiles    staff_profiles?       @relation(fields: [matched_staff_id], references: [profile_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bio_log_staff")

  @@unique([tenant_id, device_log_id], map: "idx_bio_log_unique")
  @@index([tenant_id, punch_time], map: "idx_bio_log_time")
  @@index([tenant_id, matched_staff_id, punch_time], map: "idx_bio_log_staff_time")
  @@index([tenant_id, is_processed], map: "idx_bio_log_processed")
}

// =============================
// AMBULANCE MANAGEMENT MODULE
// =============================

model ambulances {
  ambulance_id              BigInt                         @id @default(autoincrement())
  tenant_id                 BigInt
  facility_id               BigInt?
  vehicle_number            String                         @unique @db.VarChar(50)
  vehicle_type              ambulance_type
  registration_expiry       DateTime?                      @db.Date
  equipment_notes           String?
  gps_device_id             String?                        @db.VarChar(100)
  is_active                 Boolean?                       @default(true)
  created_at                DateTime?                      @default(now()) @db.Timestamp(6)
  updated_at                DateTime?                      @default(now()) @db.Timestamp(6)
  tenants                   tenants                        @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulances_tenant")
  facilities                facilities?                    @relation(fields: [facility_id], references: [facility_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulances_facility")
  trips                     ambulance_trips[]
  status_logs               ambulance_status_logs[]
  maintenance_logs          ambulance_maintenance_logs[]

  @@index([tenant_id, vehicle_number], map: "idx_ambulances_vehicle")
  @@index([tenant_id, is_active], map: "idx_ambulances_active")
}

model ambulance_drivers {
  driver_id      BigInt              @id @default(autoincrement())
  tenant_id      BigInt
  full_name      String              @db.VarChar(100)
  phone          String?             @db.VarChar(20)
  license_number String?             @db.VarChar(100)
  license_expiry DateTime?           @db.Date
  is_active      Boolean?            @default(true)
  created_at     DateTime?           @default(now()) @db.Timestamp(6)
  tenants        tenants             @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_drivers_tenant")
  trips          ambulance_trips[]

  @@index([tenant_id, is_active], map: "idx_ambulance_drivers_active")
}

model ambulance_status_logs {
  status_id    BigInt           @id @default(autoincrement())
  tenant_id    BigInt
  ambulance_id BigInt
  status       ambulance_status
  reason       String?
  changed_at   DateTime         @default(now()) @db.Timestamp(6)
  changed_by   BigInt?
  ambulances   ambulances       @relation(fields: [ambulance_id], references: [ambulance_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_status_ambulance")
  users        users?           @relation(fields: [changed_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_status_user")
  tenants      tenants          @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_status_tenant")

  @@index([tenant_id, ambulance_id, changed_at], map: "idx_ambulance_status_logs")
}

model ambulance_calls {
  call_id         BigInt                  @id @default(autoincrement())
  tenant_id       BigInt
  facility_id     BigInt?
  call_number     String                  @unique @db.VarChar(50)
  patient_id      BigInt?
  patient_name    String?                 @db.VarChar(100)
  patient_uhid    String?                 @db.VarChar(50)
  pickup_location String
  drop_location   String
  call_type       String                  @db.VarChar(50)
  priority        priority_level?
  status          ambulance_call_status?  @default(pending)
  requested_by    BigInt?
  created_at      DateTime?               @default(now()) @db.Timestamp(6)
  tenants         tenants                 @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_calls_tenant")
  facilities      facilities?             @relation(fields: [facility_id], references: [facility_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_calls_facility")
  patients        patients?               @relation(fields: [patient_id], references: [patient_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_calls_patient")
  users           users?                  @relation(fields: [requested_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_calls_user")
  trips           ambulance_trips[]

  @@index([tenant_id, status], map: "idx_ambulance_calls_status")
  @@index([tenant_id, created_at], map: "idx_ambulance_calls_created")
}

model ambulance_trips {
  trip_id         BigInt                  @id @default(autoincrement())
  tenant_id       BigInt
  call_id         BigInt
  ambulance_id    BigInt
  driver_id       BigInt?
  start_time      DateTime?               @db.Timestamp(6)
  pickup_time     DateTime?               @db.Timestamp(6)
  drop_time       DateTime?               @db.Timestamp(6)
  end_time        DateTime?               @db.Timestamp(6)
  distance_km     Decimal?                @db.Decimal(8, 2)
  fuel_cost       Decimal?                @db.Decimal(10, 2)
  trip_status     ambulance_trip_status?  @default(assigned)
  notes           String?
  created_at      DateTime?               @default(now()) @db.Timestamp(6)
  ambulance_calls ambulance_calls         @relation(fields: [call_id], references: [call_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_trips_call")
  ambulances      ambulances              @relation(fields: [ambulance_id], references: [ambulance_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_trips_ambulance")
  drivers         ambulance_drivers?      @relation(fields: [driver_id], references: [driver_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_trips_driver")
  tenants         tenants                 @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_trips_tenant")

  @@index([tenant_id, trip_status], map: "idx_ambulance_trips_status")
  @@index([tenant_id, ambulance_id], map: "idx_ambulance_trips_ambulance")
}

model ambulance_maintenance_logs {
  maintenance_id   BigInt     @id @default(autoincrement())
  tenant_id        BigInt
  ambulance_id     BigInt
  maintenance_type String     @db.VarChar(100)
  description      String?
  cost             Decimal?   @db.Decimal(10, 2)
  maintenance_date DateTime   @default(now()) @db.Timestamp(6)
  next_due_date    DateTime?  @db.Date
  performed_by     BigInt?
  created_at       DateTime?  @default(now()) @db.Timestamp(6)
  ambulances       ambulances @relation(fields: [ambulance_id], references: [ambulance_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_maintenance_ambulance")
  users            users?     @relation(fields: [performed_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_maintenance_user")
  tenants          tenants    @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_ambulance_maintenance_tenant")

  @@index([tenant_id, ambulance_id, maintenance_date], map: "idx_ambulance_maintenance_logs")
}

model parking_entries {
  entry_id       BigInt    @id @default(autoincrement())
  tenant_id      BigInt
  vehicle_number String    @db.VarChar(50)
  vehicle_type   String    @db.VarChar(50)
  driver_name    String    @db.VarChar(100)
  parking_slot   String    @db.VarChar(50)
  entry_time     DateTime  @default(now()) @db.Timestamp(6)
  exit_time      DateTime? @db.Timestamp(6)
  status         String    @default("parked") @db.VarChar(20)
  created_at     DateTime? @default(now()) @db.Timestamp(6)
  tenants        tenants   @relation(fields: [tenant_id], references: [tenant_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_parking_entries_tenant")

  @@index([tenant_id, status], map: "idx_parking_entries_status")
  @@index([tenant_id, vehicle_number], map: "idx_parking_entries_vehicle")
}

