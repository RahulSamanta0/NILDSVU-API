    "@fastify/multipart": "^9.4.0",
    "@fastify/mysql": "^5.0.2",
    "@fastify/one-line-logger": "^2.1.0",
    "@fastify/postgres": "^6.0.2",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.1",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.4",
    "fastify": "^5.7.4",
    "fastify-bcrypt": "^1.0.1",
    "fastify-plugin": "^5.1.0",
    "mysql2": "^3.16.3",
